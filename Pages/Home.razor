@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4">
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" class="rounded-circle mb-3"
                     width="120" />
                <h3>Lucas Nascimento</h3>
                <p class="text-muted">Ass. de Vendas</p>
            </div>
        </div>

        <div class="col-lg-8">
            <h2 class="mb-4">Experiência Profissional</h2>
            
            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia {
            Empresa = "Tambasa Atacadistas",
            Cargo = "Ass. de vendas",
            Inicio = "2023",
            Descricao = "Atuação na contratação de novos Rca's, suporte ao time de vendas, trativas juntamente com clientes e motoristas."
        },
        new Experiencia {
            Empresa = "Forno de Minas",
            Cargo = "Jovem Aprendiz Marketing",
            Inicio = "2022", Fim = "2023",
            Descricao = "Auxiliar no controle e envio de materiais para promotores de venda nos PDV's, auxilio no treinamento de promotores e requisão de material"
        }
    };
}